# --- LLM (pick one path) ---
# OpenAI (Responses API)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# OpenRouter → e.g. Gemini 2.5 Flash (set OPENROUTER_API_KEY, or set AUTOSPEND_LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
# OPENROUTER_API_BASE=https://openrouter.ai/api/v1
# Optional OpenRouter attribution headers:
# OPENROUTER_HTTP_REFERER=http://127.0.0.1:8787
# OPENROUTER_APP_TITLE=AutoSpend AI
# AUTOSPEND_LLM_PROVIDER=openrouter

AUTOSPEND_HOST=127.0.0.1
AUTOSPEND_PORT=8787
GOOGLE_CLIENT_ID=replace_with_google_client_id
GOOGLE_CLIENT_SECRET=replace_with_google_client_secret
GOOGLE_REDIRECT_URI=http://127.0.0.1:8787/oauth2callback
